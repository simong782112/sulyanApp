<!DOCTYPE html>
<di/div>
    <head>
        <meta http-equiv="content-type" content="text/html; charset=utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <title>Restaurant Application - Tortarendeléssel</title>
        <link rel="stylesheet" href="dist/styles.css" />
        <link href="dist/fontawesome-all.css" rel="stylesheet">

    </head>
<body>
    
 
<!--<div id="content"></div>
<div id="content2"></div>
<div id="app"></div>-->


<!-- mmenu használathoz
<nav id="menu">
    <ul>
       <li><a href="/">Home</a></li>
       <li><a href="/about">About us</a>
          <ul>
             <li><a href="/about/history">History</a></li>
             <li><a href="/about/team">The team</a></li>
             <li><a href="/about/address">Our address</a></li>
          </ul>
       </li>
       <li><a href="/contact">Contact</a></li>
    </ul>
 </nav>-->

<div id="app3">    
    <nav v-show="isMainMenuVisible" class="navbar fixed-top navbar-expand-lg navbar-dark bg-dark flex-shrink-0" style="background-color: #e3f2fd; display: none;">
        <button class="navbar-toggler navbar-toggler-right" type="button" data-toggle="collapse" data-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <a  class="navbar-brand" href="#">MySystem</a>
        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
            <div class="navbar-nav">
                <a class="nav-item nav-link" href="#" v-on:click="changeModul(0)">Pénztár <span class="sr-only">(current)</span></a>
                <!--<a class="nav-item nav-link" href="#" v-on:click="changeModul(1)">Kiadás</a>-->                
                <a class="nav-item nav-link" href="#" v-on:click="changeModul(5)">Napi kínálat</a>
                <a class="nav-item nav-link" href="#" v-on:click="changeModul(2)">Cikktörzs</a>
                <a class="nav-item nav-link" href="#" v-on:click="changeModul(3)">Helyi kiadás</a>
                <!--<a class="nav-item nav-link" href="#" v-on:click="changeModul(6)">Frissensültek</a>
                <a class="nav-item nav-link" href="#" v-on:click="changeModul(7)">Frissensült rendelés</a>-->
                <a class="nav-item nav-link" href="#" v-on:click="changeModul(9)">Torta rendelés</a>
                <a class="nav-item nav-link" href="#" v-on:click="changeModul(11)">Cukrászlista</a>
                <a class="nav-item nav-link" href="#" v-on:click="logout">Kilépés</a>
            </div>
        </div>
    </nav>

    <nav  v-cloak v-show="numVisibleModule == 6" class="navbar fixed-top navbar-expand-lg navbar-dark bg-dark flex-shrink-0" style="background-color: #e3f2fd; display: none;">
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarText" aria-controls="navbarText" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarText">
            <ul class="navbar-nav mr-auto">
            <li class="nav-item">
                <a class="nav-link" href="#" v-on:click="changeModul(0)">Vissza a pénztárba</a>
            </li>
            </ul>
            <span class="navbar-text">
                <form class="form-inline">
                    <input class="form-control mr-sm-2" type="search" placeholder="Keres" aria-label="Keres">
                    <button class="btn btn-outline-success my-2 my-sm-0" type="submit">Keres</button>
                </form>                                
            </span>
        </div>
    </nav>    

    <modal v-cloak v-if="showModalOut" v-on:close="showModalOut = false">
        <div slot="body" style="overflow-x: hidden;  height:70vh;">
            <div class="divleftp">
                <ul class="list-group">
                    <cashout-items
                        v-for="item in SelectedPenztarItem.items"
                        v-bind:name="item.name"
                        v-bind:price="item.price"
                        v-bind:menny="item.menny"
                        v-bind:ossz="item.ossz"
                        v-bind:inout="item.inout"
                        v-bind:adag="item.adag"
                        v-bind:porciozhato="item.porciozhato"
                        v-on:plus="pluszMenny(item, SelectedPenztarItem)"
                        v-on:minus="minuszMenny(item, SelectedPenztarItem)"
                        v-on:changepe="changePortionItemE(item, SelectedPenztarItem)"
                        v-on:changepf="changePortionItemF(item, SelectedPenztarItem)"                        
                        v-on:changep="(portionType, v1)=>changePortionItem(item, portionType, v1)">                        
                    </cashout-items>
                </ul>
                <hr><hr>
                <h3>Végösszeg:<br> {{ SelectedPenztarItem.szum }} HUF</h3>
            </div>
            <div class="divrightp">

                <div class="card">
                    <h3 class="card-header">                        
                        Kiszállítási adatok
                    </h3>
                    <div class="card-block">

                        <form class="container" id="needs-validation2" novalidate @submit.prevent="genSzallito">
                                
                            <div class="row">    
                                <div class="col-md-10 mb-10">
                                    <br>
                                    Kereső:
                                </div>
                                <div class="col-md-10 mb-10">
                                    <input type="text" autocomplete="off" class="form-control" id="PartnerSearch" placeholder=""  v-model="partnerSearchTxt">                                        
                                </div>
                                <div class="col-md-1 mb-1">
                                    <button type="button" class="btn btn-danger" v-on:click="cancelSearchMatch"><i class="fas fa-times"></i></button>
                                    <br>
                                </div>
                            </div>                            
                            <div class="row">    
                                <div class="col-md-8 mb-8">
                                    <label for="giveOutName">Név</label>
                                    <input type="text" autocomplete="off" class="form-control" id="giveOutName" placeholder="" v-model="giveOutObj.name" required>
                                    <div class="invalid-feedback">
                                        Nevet kötelező kitölteni
                                    </div>        
                                </div>
                            </div>
                            <div class="row">                               
                                <div class="col-md-4 mb-4">
                                    <label for="giveOutCity">Település</label>
                                    <input type="text" class="form-control" id="giveOutCity" placeholder="" v-model="giveOutObj.city" required>                                    
                                    <div class="invalid-feedback">
                                        Települést kötelező kitölteni
                                    </div>                                    
                                </div>
                                <div class="col-md-6 mb-6">
                                    <label for="validationCustom02">Cím (utca, házszám)</label>
                                    <input type="text" class="form-control" id="validationCustom02" placeholder="" v-model="giveOutObj.address">
                                    <div class="invalid-feedback">
                                        Címet kötelező kitölteni
                                    </div>
                                </div>                                 
                            </div>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label for="validationCustom03">Telefonszám</label>
                                    <input type="text" class="form-control" id="validationCustom02" placeholder="" v-model="giveOutObj.telefon" required>
                                </div>
                            </div>       
                            <div class="row">
                                <div class="col-md-6 mb-6">
                                    <label for="validationCustom04">Email</label>
                                    <input type="text" class="form-control" id="validationCustom04" placeholder="" v-model="giveOutObj.email">
                                </div>
                            </div>                                                   
                            <div class="row">
                                <div class="col-md-3 mb-3">    
                                    <label for="validationCustom04">Szállítólevél</label>
                                    <br>
                                    <label class="switch">
                                        <input type="checkbox" v-model="giveOutObj.genSzallito">
                                        <span class="slider round"></span>
                                    </label>                                    
                                </div>
                                <div class="col-md-3 mb-3">    
                                    <label for="validationCustom04">Számla</label>
                                    <br>
                                    <label class="switch">
                                        <input type="checkbox" v-model="giveOutObj.genSzamla">
                                        <span class="slider round"></span>
                                    </label>  
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-3 mb-3">                                                                              
                                    <button class="btn btn-success" type="submit">Kijelölt dokumentumok elkészítése</button>&nbsp;
                                </div>
                            </div>
                           
                        </form>  

                    </div>
                </div>

            </div>            
        </div>                 
        <h3 slot="header">Pénztártétel kiadása</h3>               
    </modal> 

    <modal v-cloak v-if="showModalKoret" v-on:close="showModalKoret = false">
        <div slot="body" style="overflow-x: hidden;  height:60vh;">
            <div class="wrapper">                            
                <main>                
                    <div class="flex-grid">   
                        <my-blocks 
                            v-for="koret in koretek"                 
                            v-bind:name="koret.name"
                            v-bind:price="koret.price"
                            v-on:add="addKoretData(koret)"
                            v-bind:class="{ flex3: koret.id == 10,  flex4: koret.id == 68}">                
                        </my-blocks>                                                                           
                    </div>                                                                                    
                </main>
            </div>                                        
        </div>                 
        <h3 slot="header">Köretek</h3>        
    </modal>     

    <modal v-cloak v-if="showModalKoretForFriss" v-on:close="showModalKoretForFriss = false">
            <div slot="body" style="overflow-x: hidden;  height:60vh;">
                <div class="wrapper">                            
                    <main>                

                        <div class="wrapper">
                            <div class="box">
                                <div v-for="koret in koretek" v-bind:id=" 'K0_' + koret.id"  v-on:click="addKoretToFriss(koret)">
                                    <img width="180" height="145" v-bind:src="'http://www.marikakonyhaja.hu/upload/friss/' + koret.kep">                    
                                    <h3>{{koret.name}}</h3>
                                    <p>{{koret.price}} Ft</p>                                    
                                </div>
                            </div>
                        </div>

                        <!--<div style="display: flex;flex-flow: row wrap;align-items: stretch;align-content: stretch;justify-content: space-around;">
                            <div v-for="koret in koretek" v-on:click="addKoretToFriss(koret)" style="border: 1px dotted #e1caaa; margin: 15px; padding: 15px; text-align: center;">
                                <img width="200" height="160" src="http://www.marikakonyhaja.hu/upload/friss/hasab.png">        

                                <h3>{{koret.name}}</h3>
                                <p>{{koret.price}}</p>
                            </div>
                        </div>   -->                      
                    </main>
                </div>                                        
            </div>                 
            <h3 slot="header">Köretek</h3>        
    </modal>      

    <modal v-cloak v-if="showModal" v-on:close="showModal = false">
        <div slot="body" style="overflow-x: hidden;  height:60vh;">
            <div class="divleftp">
                <ul class="list-group">
                    <cashout-items
                        v-for="item in SelectedPenztarItem.items"
                        v-bind:name="item.name"
                        v-bind:price="item.price"
                        v-bind:menny="item.menny"
                        v-bind:ossz="item.ossz"
                        v-bind:inout="item.inout"
                        v-bind:adag="item.adag"
                        v-bind:porciozhato="item.porciozhato"
                        v-on:plus="pluszMenny(item, SelectedPenztarItem)"
                        v-on:minus="minuszMenny(item, SelectedPenztarItem)"
                        v-on:changepe="changePortionItemE(item, SelectedPenztarItem)"
                        v-on:changepf="changePortionItemF(item, SelectedPenztarItem)"                                                
                        v-on:changep="(portionType, v1)=>changePortionItem(item, portionType, v1)">                        
                    </cashout-items>
                </ul>
            </div>
            <div class="divrightp">
                <div class="wrapper">                            
                    <main>                
                        <div class="flex-grid">   
                            <div class='flex-grid-item' v-on:click='selkategoria(0)'>Napi</div>    
                            <my-kodblocks 
                                v-for="kat in kategoriak"                 
                                v-bind:name="kat.name"
                                v-on:selkat="selkategoria(kat)"
                                v-bind:class="{ flex3: kat.spec == 1}"
                                >                
                            </my-kodblocks>       
                            <div class="flex-grid-item blank"></div>
                            <div class="flex-grid-item blank"></div>
                            <div class="flex-grid-item blank"></div>
                            <div class="flex-grid-item blank"></div>
                            <div class="flex-grid-item blank"></div>                                                           
                        </div>
                                    
                        <div class="flex-grid">                                           
                            <my-blocks 
                                v-for="termek in termekek"                 
                                v-bind:name="termek.name"
                                v-bind:price="termek.price"
                                v-on:add="addData(termek)"
                                v-bind:class="{ flex3: termek.id == 10,  flex4: termek.id == 68}">                
                            </my-blocks>
                            <div class="flex-grid-item blank"></div>
                            <div class="flex-grid-item blank"></div>
                            <div class="flex-grid-item blank"></div>
                            <div class="flex-grid-item blank"></div>
                            <div class="flex-grid-item blank"></div>                                  
                        </div>   
                                                        
                    </main>
                </div>                        
            </div>
        </div>                 
        <h3 slot="header">{{ modalHeaderTitle }}</h3>        
    </modal>    

    <modal v-cloak v-if="showModalNumPad" v-on:close="showModalNumPad = false">
        <div slot="body" style="overflow-x: hidden;  height:60vh;">
            
            <div class="divleftnp">
                <input type="text" style="width: 420px;" autocomplete="off" class="form-control" id="NumPadNumber" placeholder=""  v-model="NumPadNumberTxt">                                                        
                <div class="numpad">
                    <div class="button" v-on:click="clickNumPadButton(1)">1</div>
                    <div class="button" v-on:click="clickNumPadButton(2)">2</div>
                    <div class="button" v-on:click="clickNumPadButton(3)">3</div>
                    <div class="button" v-on:click="clickNumPadButton(4)">4</div>
                    <div class="button" v-on:click="clickNumPadButton(5)">5</div>
                    <div class="button" v-on:click="clickNumPadButton(6)">6</div>
                    <div class="button" v-on:click="clickNumPadButton(7)">7</div>
                    <div class="button" v-on:click="clickNumPadButton(8)">8</div>
                    <div class="button" v-on:click="clickNumPadButton(9)">9</div>
                    <div class="button" v-on:click="clickNumPadButton(0)">0</div>
                    <div class="button" v-on:click="clickNumPadOK()"><i class="fas fa-arrow-right"></i></div >
                </div> 
            </div>        
            <div>
                <p># {{ SelectedPenztarItem.id}}</p>
                <h2><u> Módosítandó tétel: </u></h2><br>
                <h3> {{ selectedFoodOutItem.name }}</h3>
                <br>
                Mennyiség: <span class="badge badge-primary badge-pill"> {{ selectedFoodOutItem.menny }}</span>
                <br>
                Kalkulált összeg: {{ KalkPrice }} HUF

            </div>
           <!-- <div style="float: left; width: 40%;">
                <div class="flex-grid">                                           
                    <my-num 
                        v-for="n in 9"                 
                        v-bind:num="n"
                        v-on:add="onClickedEvent(n)">                
                    </my-num>
                    <div class="flex-grid-item blank"></div>
                </div>             
            </div>   -->


        </div>                 
        <h3 slot="header">NumPad</h3>        
    </modal>     

    <modal v-cloak v-if="showModalTortaArazas" v-on:close="showModalTortaArazas = false">
        <div slot="body" style="overflow-x: hidden;  height:60vh;">
            <h2>Normál</h2>
            <ul class="list-group list-group-flush">
                <li v-for="n in normalTortaArak" class="list-group-item">{{n.kategoria}}. kategória <span class="badge badge-primary badge-pill">&nbsp;{{n.szeletar}} Ft</span></li>
            </ul>
            <h2>Burkolt</h2>
            <ul class="list-group list-group-flush">
                <li v-for="n in burkoltTortaArak" class="list-group-item">
                    {{n.kategoria}}. kategória - 
                    <span v-if="n.diszites == 'EGY'">Egyszerű</span> 
                    <span v-if="n.diszites == 'KUL'">Különleges</span> 
                    <span v-if="n.diszites == 'EXT'">Extra</span> 
                    &nbsp;
                    <span class="badge badge-primary">{{n.szeletar}} Ft</span></li>
            </ul>

        </div>

    </modal>
    
    <div v-cloak v-show="isMainHeaderVisible" class="alert alert-success" id="infobox" style="margin-top: 55px; margin-bottom: 0px;">                
            <h4>{{ moduleTitle }} ({{versionX}})</h4>  
            
            <button v-if="numVisibleModule == 0" type="button" class="btn btn-primary" v-on:click="penztarToFoodOut"><i class="fas fa-plus"></i></button>
            <button v-if="numVisibleModule == 0" type="button" class="btn btn-primary" v-on:click="showTortaRendeles(0)"><i class="fas fa-plus"></i></button>
            {{ cntLoading }}          
        <div style="float: right; width: 2%;" v-show="isLoading"><div class="loader"></div></div>   
    </div>      

    <section v-if="numVisibleModule == 0" id="PenztarSection">
        <div v-cloak class="card-columns" style="margin-left: 25px;">

            <div class="card" v-for="p in penztar">
                <div class="card-block">
                    <button type="button" data-toggle="modal" data-target="#TermekModal" class="btn btn-primary btn-lg" v-on:click="addTermek(p)">
                        <i v-if="p.mfid == 0" class="fab fa-elementor fa-lg"></i> 
                        <font v-if="p.mfid == 0"> {{ p.id }}</font>
                        <i v-if="p.mfid > 0" class="fas fa-globe fa-lg"></i> 
                        <font v-if="p.mfid > 0"> {{ p.mfid }}</font>                         
                    </button>
                    &nbsp;
                    <strong>{{ p.ido }}</strong>
                    <ul class="list-group">

                            <cashout-items
                                v-for="item in p.items"
                                v-bind:name="item.name"
                                v-bind:price="item.price"
                                v-bind:menny="item.menny"
                                v-bind:ossz="item.ossz"
                                v-bind:inout="item.inout"
                                v-bind:adag="item.adag"
                                v-bind:porciozhato="item.porciozhato"
                                v-on:plus="pluszMenny(item, p)"
                                v-on:minus="minuszMenny(item, p)"
                                v-on:shownum="showNumPad('CASHOUT', item, p)"
                                v-on:changepe="changePortionItemE(item, p)"
                                v-on:changepf="changePortionItemF(item, p)"
                                v-on:changep="(portionType, v1)=>changePortionItem(item, portionType, v1)">                                                
                            </cashout-items>                        

                        <li class="list-group-item" style="text-align: center; background-color: #036f96; color: white;">
                            <div style="width: 100%">
                                <h3>{{ p.szum }}  HUF</h3>
                                <button class="btn btn-success" v-on:click="showOutDialog(p)"><i class="fas fa-outdent fa-lg"></i> Kiadás</button>                      
                                <button class="btn btn-warning" v-on:click="pay(p)"><i class="far fa-money-bill-alt fa-lg"></i> Fizetés</button>                      
                            </div>
                        </li>   
                
                    </ul>

                </div>
            </div>

        </div>         
    </section>

    <section v-if="numVisibleModule == 1" id="TermekViewSection">
        <div v-cloak class="col-sm-12 col-md-12" style="padding-left:2px; padding-right: 2px; margin-top: 55px;">

                <div class="card">
                    <h3 class="card-header">
                        <a href="#" v-on:click="changeModul(2)"><i class="fas fa-chevron-left"></i></a>
                        Termékadatlap
                    </h3>
                    <div class="card-block">

                        <form class="container" id="needs-validation" novalidate @submit.prevent="submitTermekData">
                            <!--<div class="row">
                                <div class="col-md-4 mb-4">                                    
                                    <ul>
                                        <li v-for="file in files">{{file.name}} - Error: {{file.error}}, Success: {{file.success}}</li>
                                    </ul>                                    
                                    <file-upload
                                        ref="upload"
                                        v-model="files"
                                        post-action="/post.method"
                                        put-action="/put.method"
                                        @input-file="inputFile"
                                        @input-filter="inputFilter"
                                        >
                                        Upload file
                                    </file-upload>
                                    <button v-show="!$refs.upload || !$refs.upload.active" @click.prevent="$refs.upload.active = true" type="button">Start upload</button>
                                    <button v-show="$refs.upload && $refs.upload.active" @click.prevent="$refs.upload.active = false" type="button">Stop upload</button>                                                              
                                </div>                                
                            </div>-->
                            <div class="row">    
                                <div class="col-md-4 mb-3">
                                    <label for="validationCustom01">Név</label>
                                    <input type="text" class="form-control" id="validationCustom01" placeholder="" v-model="termekitem.name" required>
                                    <div class="invalid-feedback">
                                        Nevet kötelező kitölteni
                                    </div>        
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label for="validationCustom02">Ár</label>
                                    <input type="text" class="form-control" id="validationCustom02" placeholder="" v-model="termekitem.price" value="" required>
                                    <div class="invalid-feedback">
                                        Árat kötelező kitölteni
                                    </div>
                                </div>                                
                                <div class="col-md-4 mb-3">
                                    <label for="validationCustom03">Menü</label>
                                    <select class="form-control" id="validationCustom03" name="kateg" v-model="termekitem.kat" required>                
                                        <option v-for="kat in kategoriak" v-bind:value="kat.kod">{{ kat.name }}</option>              
                                    </select> 
                                    <div class="invalid-feedback">
                                        Kategóriát kötelező kitölteni
                                    </div>                                    
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-2 mb-2">
                                    <label for="validationCustom04">Torta kategória</label>
                                    <br>                                 
                                    <select class="form-control" id="validationCustom03" name="torta_kateg" v-model="termekitem.isTortaKategoria">                
                                        <option v-for="tk in torta_kategoriak" v-bind:value="tk.value">{{ tk.name }}</option>              
                                    </select> 
                                </div>                             
                            </div>                            
                    
                            <input type="hidden" name="id" v-model="termekitem.id">
                            <button class="btn btn-success" type="submit">Mentés</button>
                        </form>                          

                    </div>
                </div>
          
        </div>
    </section> 
    
    <section v-if="numVisibleModule == 2" id="TermekListSection">          
        <div v-cloak class="col-sm-12 col-md-12" style="padding-left:2px; padding-right: 2px; margin-top: 58px;">
            <div class="flex-grid">
                <div class="p-2"  v-for="kat in kategoriak">
                    <button type="button" class="btn btn-outline-info"  v-bind:class="{ 'btn-danger': kat.kod == termekFilterKateg}" v-on:click="refreshTermekKeszlet(kat.kod)">{{ kat.name }}</button>
                </div>
            </div>
                        
            <div class="input-group">
                <div class="input-group-prepend">
                    <button type="button" class="btn btn-primary" v-on:click="addTermekToKeszlet"><i class="fas fa-plus"></i></button>
                </div>
                <input type="text" class="form-control" placeholder="Search" v-model="termekFilterStr">
                <div class="input-group-append">
                    <button type="button" class="btn btn-primary" v-on:click="termekfilter"><i class="fas fa-search"></i></button>
                </div>
            </div>
        </div>
        
        <my-card 
            v-for="termek in termekek"   
            v-bind:id="termek.id"          
            v-bind:name="termek.name"
            v-bind:napi="termek.isNapi"
            v-bind:azon ="termek.azon"
            v-on:goto="navigateTo(1, termek)"
            v-on:delete="deleteTermek(termek)"
            v-on:setnapikinalat="setmainapikinalatba(termek)"
            v-bind:price="termek.price">                
        </my-card>
        
    </section>    

    <section v-if="numVisibleModule == 3" id="FoodOutSection">
        <div v-cloak class="col-sm-12 col-md-12" style="padding-left:2px; padding-right: 2px;">
                <ul class="nav" v-show="isFoodOutHeader">
                    <li  style="width:15%" class="nav-item">
                        <a class="nav-link active" href="#" v-on:click="penztarFromFoodOut()">Vissza a pénztárba</a>
                    </li>
                    <li style="width:50%">
                        &nbsp;
                    </li>
                    <li>
                        <a class="nav-link active" href="#"> Összesen:  <strong>{{ totalAmount }}</strong> HUF</a>                                    
                    </li>
                    <li style="text-align: right;list-style-position: inside;">
                        <button class="btn btn-success" v-on:click="toCashout">Pénztárba</button>
                    </li>
                </ul>
                <div id='main'>                            
                    <article>
                        <div style="overflow-x: hidden;  height:100vh;">
                            <div v-show="isLoading" class="loader" style="position: absolute; right: 0;"></div>
                            <div>                            
                                <main>                
                                    <div class="flex-grid">   
                                        <div class='flex-grid-item'><button style="height:100%; width:100%;" class="btn btn-warning" v-on:click='selkategoria(0)'>Napi</button></div>
                                        <my-kodblocks 
                                            v-for="kat in kategoriak"                 
                                            v-bind:name="kat.name"
                                            v-on:selkat="selkategoria(kat)"
                                            v-bind:class="{ flex3: kat.spec == 1}"
                                            >                
                                        </my-kodblocks>   
                                        <div class="flex-grid-item"><button style="height:100%; width:100%;" class="btn btn-info"  v-on:click="addCsomagolasItem">Csomagolás</button> </div>
                                        <div class="flex-grid-item"><button style="height:100%; width:100%;" class="btn btn-info"  v-on:click="addSzallitasItem(1)">Szállítás 100</button></div>
                                        <div class="flex-grid-item"><button style="height:100%; width:100%;" class="btn btn-info"  v-on:click="addSzallitasItem(2)">Szállítás 300</button></div>
                                        <div class="flex-grid-item"><button style="height:100%; width:100%;" class="btn btn-info"  v-on:click="addSzallitasItem(3)">Szállítás 500</button></div>                                
                                                
                                        <div class="flex-grid-item blank"></div>
                                        <div class="flex-grid-item blank"></div>
                                        <div class="flex-grid-item blank"></div>
                                        <div class="flex-grid-item blank"></div>
                                        <div class="flex-grid-item blank"></div>                                                               
                                    </div>
        
                                    <div class="flex-grid">                                           
                                        <my-blocks 
                                            v-for="termek in termekek"                 
                                            v-bind:name="termek.name"
                                            v-bind:korettel="termek.isKorettel"
                                            v-bind:price="termek.price"
                                            v-on:add="addDataToFoodOut(termek)"
                                            v-bind:class="{ flex3: termek.id == 10,  flex4: termek.id == 68}">                
                                        </my-blocks>
                                        <div class="flex-grid-item blank"></div>
                                        <div class="flex-grid-item blank"></div>
                                        <div class="flex-grid-item blank"></div>
                                        <div class="flex-grid-item blank"></div>
                                        <div class="flex-grid-item blank"></div>                                        
                                    </div>                                            
                                </main>
                            </div>                                        
                        </div>        
                                           
                    </article>
                    <nav>                                
                        <button v-cloak type="button" class="btn btn-primary btn-lg btn-block" v-bind:class="{ 'btn-danger': selOutType == 'IN'}" v-on:click="switchOutIn('IN')"><i class="fas fa-utensils"></i> Helyben ( {{ totalCountIN }} db)</button>
                        <div style="overflow:scroll; height:100vh;">                  
                            <foodout-card 
                                v-for="item in cashoutlist"                 
                                v-bind:name="item.mealName"
                                v-bind:price="item.price"
                                v-bind:menny="item.menny"
                                v-bind:adag="item.adag"
                                v-bind:porciozhato="item.porciozhato"
                                v-bind:korettel="item.korettel"
                                v-on:shownum="showNumPad('FOODOUT', item)"
                                v-on:plus="pluszFoodOutItemMenny(item)"
                                v-on:minus="minuszFoodOutItemMenny(item)"
                                v-on:changep="changePortionFoodOut(item)"
                                v-on:addkoret="showKoretModal(item)"       
                                v-on:addpercent="addPercentToItem(item)">         
                            </foodout-card>                    
                        </div>       
                    </nav>
                    <nav>
                        <button v-cloak type="button" class="btn btn-primary btn-lg btn-block" v-bind:class="{ 'btn-danger': selOutType == 'OUT'}" v-on:click="switchOutIn('OUT')"><i class="fas fa-car fa-lg"></i> Elvitelre ( {{ totalCountOUT }} db)</button>                    
                        <div style="overflow:scroll; height:100vh;">                  
                            <foodout-card 
                                v-for="item in cashoutlist2"                 
                                v-bind:name="item.mealName"
                                v-bind:price="item.price"
                                v-bind:menny="item.menny"
                                v-bind:adag="item.adag"
                                v-bind:porciozhato="item.porciozhato"
                                v-bind:korettel="item.korettel"
                                v-on:shownum="showNumPad('FOODOUT', item)"
                                v-on:plus="pluszFoodOutItemMenny(item)"
                                v-on:minus="minuszFoodOutItemMenny(item)"
                                v-on:changep="changePortionFoodOut(item)"
                                v-on:addkoret="showKoretModal(item)"    
                                v-on:addpercent="addPercentToItem(item)">                     
                            </foodout-card>                            
                    </nav>                    
                </div>
            
        </div>
    </section> 

    <section v-if="numVisibleModule == 4" id="LoginSection">
        <div slot="body">
            <div class="loginmodal-container">                
              
              <h3><i class="fas fa-sign-in-alt"></i> Bejelentkezés</h3>
              <form class="container" id="needs-validation" novalidate @submit.prevent="login">
                    <input type="text" class="form-control" id="validationEmail" placeholder="Email" v-model="username" v-on:keyup.13="login" value="" required>
                    <div class="invalid-feedback">
                        Email kitöltése kötelező
                    </div>
    
                    <input type="password" class="form-control" id="validationPass" placeholder="Jelszó" v-model="password" v-on:keyup.13="login" value="" required>
                    <div class="invalid-feedback">
                        Jelszó kitöltése kötelező
                    </div>                
                <input type="submit" name="login" class="login loginmodal-submit" value="Bejelentkezés">
              </form>             
              <!--<div class="login-help">
                <a href="#">Register</a> - <a href="#">Forgot Password</a>
              </div>-->
            </div>
            <div style="margin-top: 20px; text-align: center; width: 100%;">
                <img style="width: 240px; height: 70px;" src="http://www.mysystem.hu/eszamla/images/mysystem.jpg">                                    
            </div>   
            <div v-cloak  style="margin-top: 20px; text-align: center; width: 100%;">               
                <span>
                    {{versionX}}
                </span>
            </div>
            
        </div>
    </section>

    <section v-if="numVisibleModule == 5" id="NapiSection">
        <div v-cloak class="col-sm-12 col-md-12" style="padding-left:2px; padding-right: 2px; margin-top: 58px;">
            <my-card 
                v-for="termek in napiLista"   
                v-bind:id="termek.spec_napi_id"          
                v-bind:name="termek.name"
                v-bind:napi="termek.isNapi"
                v-bind:azon ="termek.azon"
                v-on:delete="deleteFromNapi(termek)"
                v-bind:price="termek.price">                
            </my-card>     
        </div>
    </section>    

    <section v-if="numVisibleModule == 6" id="FrissSection">
            
            <div v-cloak class="col-sm-12 col-md-12" style="padding-left:0px; padding-right: 0px; margin-top: 75px;">
                            
                <my-friss-card 
                    v-for="termek in frissForKitchenLista"   
                    v-bind:id="termek.id"        
                    v-bind:pid="termek.pid"     
                    v-bind:name="termek.name"
                    v-bind:menny="termek.menny"
                    v-bind:azon ="termek.azon"
                    v-bind:image ="termek.kep"
                    v-bind:adag ="termek.adag"
                    v-bind:ido ="termek.keres_datum"
                    v-bind:idophp ="termek.eltelt_ido"
                    v-bind:typeinout = "termek.typeInOut"
                    v-bind:napisorszam="termek.napisorszam"
                    v-on:delete="deleteFromFrissList(termek.pid)">
                </my-friss-card>                 

            </div>


    </section>

    <section v-if="numVisibleModule == 7" id="FrissRendeloSection">
        <!-- subheader -->
        
        <div v-cloak>
            <iframe src="http://marikakonyhaja.hu/tv/999" style="width: 100%; height: 250px; margin:0;" frameBorder="0"></iframe>
        </div>                       
        <br>
        <div v-cloak style="position: absolute; top: 50%; left: 50%; margin:auto; width: 50px;" v-show="isLoading"><div class="loader"></div></div>

        <!-- <img v-show="numFrissSubModul == 0"  v-cloak style="width: 100%" src="http://marikakonyhaja.hu/templates/pict/marika/fej2.png"> -->
        <div v-cloak style="margin: auto; text-align: center;">
            <h1 v-show="numFrissSubModul == 0" class="display-4 animated infinite bounce delay-2s" v-on:click="changeFrissSubModul(FrissHeadBackSectionNumber)"><i v-show="numFrissSubModul > 0" class="fas fa-chevron-left"></i> {{FrissHeadTitle}}</h1>            
            <h1 v-show="numFrissSubModul > 0" class="display-4" v-on:click="changeFrissSubModul(FrissHeadBackSectionNumber)"><i v-show="numFrissSubModul > 0" class="fas fa-chevron-left"></i> {{FrissHeadTitle}}</h1>            
            <p class="lead animated infinite pulse delay-2s" style="margin-left: 50px;">{{FrissHeadSubTitle}}</p>
            <hr class="my-4">        
        </div>

        <div v-cloak class="frissorderdiv" v-show="numFrissSubModul > 0" >
            <div style="display: flex;flex-flow: row wrap;align-items: stretch;align-content: stretch;justify-content: space-around;">
                <div v-on:click="openFrissBagForm()" id="W1_KOSAR" style="margin: 0px; padding: 15px; text-align: center; width: 250px;">
                    <!--<i class="fas fa-shopping-cart fa-4x" style="color: red"></i>-->
                    <img style="width: 80px; height: 80px;" src="http://www.marikakonyhaja.hu/templates/pict/marika/spa/shop.png">
                    <h3>{{FrissOrderObj.list.length}} tétel</h3>                    
                    <h5>{{FrissOrderObj.type}}</h5>
                </div>                       
            </div>

            <div v-show="numFrissSubModul == 2"  style="display: flex;flex-flow: row wrap;align-items: stretch;align-content: stretch;justify-content: space-around;">                      

                <div v-on:click="scrollToTop()" id="W1_TOP" style="margin: 0px; padding-top: 300px; text-align: center; width: 250px;">
                    <!--<i class="fas fa-shopping-cart fa-4x" style="color: red"></i>-->
                    <img src="http://www.marikakonyhaja.hu/templates/pict/marika/spa/top64.png">                                       
                </div>                       

                <div v-on:click="scrollToDown()" id="W1_DOWN" style="margin: 0px; padding-top: 25px; text-align: center; width: 250px;">
                    <!--<i class="fas fa-shopping-cart fa-4x" style="color: red"></i>-->
                    <img src="http://www.marikakonyhaja.hu/templates/pict/marika/spa/down64.png">                                       
                </div>                       
            </div>            
        </div>


        <!-- submain -->
        <!-- welcome -->
        <div v-cloak v-show="numFrissSubModul == 0" class="col-sm-12 col-md-12 animated zoomIn" style="padding-left:0px; padding-right: 0px; margin-top: 0px;">            
            <!--<img  v-cloak style="width: 100%" src="http://marikakonyhaja.hu/templates/pict/marika/fej2.png">-->

            <div class="jumbotron" style="background-color: white;">
                <div style="display: flex;flex-flow: row wrap;align-items: stretch;align-content: stretch;justify-content: space-around;">
                    <div v-on:click="openFrissKategoriaForm('HELYBEN')" id="W1_HELYBEN" style="border: 1px dotted #e1caaa; margin: 15px; padding: 15px; text-align: center; width: 300px;">
                        <!--<i class="fas fa-utensils fa-10x"></i>-->
                        <img src="http://www.marikakonyhaja.hu/templates/pict/marika/spa/restaurant.png">
                        <h3>Helyben</h3>
                    </div>                       
                    <div v-on:click="openFrissKategoriaForm('ELVITELRE')" id="W1_ELVITELRE" style="border: 1px dotted #e1caaa; margin: 15px; padding: 15px; text-align: center; width: 300px;">
                        <!-- <i class="fas fa-car fa-10x"></i>            -->                        
                        <img src="http://www.marikakonyhaja.hu/templates/pict/marika/spa/basket.png">
                        <h3>Elvitelre</h3>
                    </div>                       
                </div>                   
            </div>
            
        </div>

        <!-- kategóriák -->
        <div v-cloak v-show="numFrissSubModul == 1" class="col-sm-12 col-md-12 animated zoomIn" style="padding-left:0px; padding-right: 0px; margin-top: 0px;">            

            <div class="wrapper">
                <div class="box2">
                  <div v-for="frisskat in FrissKatList" v-bind:id=" 'S0_' + frisskat.id"  v-on:click="openFrissTermekekForm(frisskat, frisskat.id)">
                    <img width="200" height="160"  :src="'http://www.marikakonyhaja.hu/upload/friss/ico/' + frisskat.id + '.png'">                    
                    <h3>{{frisskat.name}}</h3>
                  </div>
                </div>
            </div>
                                          
        </div>

        <!-- termékek -->
        <div v-cloak v-show="numFrissSubModul == 2" class="col-sm-12 col-md-12 animated zoomIn" style="padding-left:0px; padding-right: 0px; margin-top: 0px;">
            
            <div class="wrapper">
                <div class="box">
                  <div v-for="termek in termekek2" v-bind:id=" 'S1_' + termek.id" v-on:click="openFrissOrderAddForm(termek)" v-show="termek.isTiltvaSpec1 == false">
                    <img width="200" height="160" v-show="termek.kep"  v-bind:src="'http://www.marikakonyhaja.hu/upload/friss/' + termek.kep">                    
                    <h3>{{termek.name}}</h3>
                    <p>{{termek.price}} Ft</p>                      
                  </div>
                </div>
            </div>

        </div>        

        <!-- kiválasztott termék összeállítása -->
        <div v-cloak v-show="numFrissSubModul == 3" class="col-sm-12 col-md-12 animated zoomIn" style="padding-left:0px; padding-right: 0px; margin-top: 0px;">                                               
            
            <div class="card text-center" style="width: 60rem; position: relative; margin: 0 auto;">
                <img style="position: relative; margin: 0 auto;" width="180" height="150" v-show="SelectedFrissTermek.kep && SelectedFrissTermek.kep.length > 0 && SelectedFrissTermek.kep != 'undefined'"  v-bind:src="'http://www.marikakonyhaja.hu/upload/friss/' + SelectedFrissTermek.kep">                    
                <i v-show="SelectedFrissTermek.plusKoret && SelectedFrissTermek.plusKoret.length > 0" class="fas fa-plus"></i>
                <img style="position: relative; margin: 0 auto;" v-show="SelectedFrissTermek.plusKoret && SelectedFrissTermek.plusKoret.length > 0" width="200" height="160"  v-bind:src="'http://www.marikakonyhaja.hu/upload/friss/' + SelectedFrissTermek.pluskoret1kep">        
                <div class="card-body">
                  <h3 class="card-title">{{SelectedFrissTermek.mealName}}</h3>
                  <p class="card-text">.</p>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item" v-show="SelectedFrissTermek.korettel && SelectedFrissTermek.plusKoret && SelectedFrissTermek.plusKoret.length == 0">
                        <button type="button" v-on:click="openKoretToFrissDialog()" class="btn btn-success btn-lg">Köret választása</button>                      
                    </li>        
                    <li class="list-group-item">
                        Adag: {{SelectedFrissTermek.adagStr}}
                        <a href="#" class="btn btn-secondary" v-bind:class="{ 'btn-warning': SelectedFrissTermek.adag === 'E'}" v-on:click="changeAdagFrissSelected('E')"><i class="fas fa-circle fa-lg"></i></a>
                        &nbsp;
                        <a href="#" class="btn btn-secondary" v-bind:class="{ 'btn-warning': SelectedFrissTermek.adag === 'F'}" v-on:click="changeAdagFrissSelected('F')"><i class="fas fa-adjust fa-lg"></i></a>        
                    </li>
                    <li class="list-group-item">
                        <h3 class="card-title">Ár: {{SelectedFrissTermek.price}} Ft</h3>
                    </li>
                </ul>
                <div class="card-body">
                  <button type="button" v-on:click="addFrissOrder(SelectedFrissTermek)" class="btn btn-success btn-lg">Hozzáadás a rendeléshez</button>          
                  &nbsp;
                  <button type="button" v-on:click="emptyFrissOrder(SelectedFrissTermek)" class="btn btn-danger btn-lg">Alaphelyzetbe állítás</button>                     
                </div>
              </div>            
                      
        </div>        

        <!-- kosár -->
        <div v-cloak v-show="numFrissSubModul == 4" class="col-sm-12 col-md-12 animated zoomIn" style="padding-left:15px; padding-right: 15px; margin-top: 0px;">                                    

            <h3 v-show="FrissOrderObj.list && FrissOrderObj.list.length > 0">Fogyasztás: {{FrissOrderObj.type}}</h3>
            <div v-cloak class="col-sm-12 col-md-12" style="padding-left:2px; padding-right: 2px; margin-top: 58px;">
                <h3 v-show="FrissOrderObj.list.length == 0">A kosár üres</h3>
                <my-card 
                    v-for="outitem in FrissOrderObj.list"                       
                    v-bind:id="outitem.id"          
                    v-bind:image="outitem.kep"    
                    v-bind:image2="outitem.pluskoret1kep"  
                    v-bind:canchangemenny="true"       
                    v-bind:name="outitem.menny + ' x ' + outitem.mealName + ' ('+ outitem.adag + ')'"
                    v-on:delete="deleteFromFrissOrder(outitem)"
                    v-on:chmennyplusz="changeMennyFrissSelected(outitem, '+')" 
                    v-on:chmennymin="changeMennyFrissSelected(outitem, '-')" 
                    v-bind:price="outitem.price">                
                </my-card>     
            </div>                      
            <hr class="my-4">        
            <h2>Összesen: {{FrissOrderObj.totalAmount}} Ft</h2>
            <hr class="my-4">        
            <p v-show="FrissOrderObj.list && FrissOrderObj.list.length > 0">
                <button type="button" class="btn btn-success btn-lg" v-on:click="saveFrissOrder()">Megrendelés</button>                       
            </p>
            <p v-show="FrissOrderObj.list.length == 0">
                <button type="button" class="btn btn-success btn-lg" v-on:click="changeFrissSubModul(1);">Frissensült kiválasztása</button>                       
            </p>
            
        </div>

        <!-- kosárba tétel után -->         
        <div v-cloak v-show="numFrissSubModul == 5" class="col-sm-12 col-md-12 animated zoomIn" style="padding-left:15px; padding-right: 15px; margin-top: 0px;">                                    
            <div class="jumbotron" style="background-color: white;">
                <div style="display: flex;flex-flow: row wrap;align-items: stretch;align-content: stretch;justify-content: space-around;">
                    <div v-on:click="selectDir('SEL')" id="M1_SEL" style="border: 1px dotted #e1caaa; margin: 15px; padding: 15px; text-align: center; width: 300px;">                        
                        <!--<i class="fas fa-cart-plus fa-10x"></i>-->
                        <img src="http://www.marikakonyhaja.hu/templates/pict/marika/spa/add.png">
                        <h3>További étel kiválasztása</h3>
                    </div>                       
                    <div v-on:click="selectDir('ORDERANDPRINT')" id="M1_ORDERANDPRINT" style="border: 1px dotted #e1caaa; margin: 15px; padding: 15px; text-align: center; width: 300px;">                        
                        <!-- <i class="fas fa-print fa-10x"></i>           -->
                        <img src="http://www.marikakonyhaja.hu/templates/pict/marika/spa/ok.png">
                        <h3>Rendelés elküldése és nyomtatása</h3>
                    </div>                       
                </div>                   
            </div>        
        </div>

        <!-- Nyomtatás indítása -->
        <div v-cloak v-show="numFrissSubModul == 6" class="col-sm-12 col-md-12 animated zoomIn" style="padding-left:15px; padding-right: 15px; margin-top: 0px;">                                    
            <h3 style="text-align: center;">Köszönjük rendelését!</h3>
            <h3 style="text-align: center;">Kérem vegye el a blokkot és vigye a kasszához!</h3>
            <h3 style="text-align: center;">Jó étvágyat!</h3>

            <div id='DivIdToPrint'>
                <br>
                <div v-cloak style="margin:auto; width:300px; background-color: rgba(196, 116, 116, 0.842);">
                    <div class="card">                                                            
                        <div style="width: 100%; text-align: center;">Marika konyhája Családi Gyorsétterem<br>{{FrissOrderObj.type}}</div>                    
                        <br>
                        <div class="card">
                            <div style="width: 100%; text-align: center; padding-top: 10px;"><b>RENDELÉS #{{FrissNewSorszam}} </b></div>
                            <i>------------------------------------------------</i>                    
                            <table v-for="item in frissensultek" style="width: 100%" cellpadding="0" cellspacing="0">                        
                                <tr>
                                    <td style="padding-left:15px;" colspan="2">{{item.menny}} db</td>
                                </tr>
                                <tr>
                                    <td style="width: 80%; font-size:12px;">{{ item.name }} </td>
                                </tr>
                            </table>                           
                        </div>    
                        <i>------------------------------------------------</i>                     
                        
                        <div style="text-align: center">{{FrissNewKeresDatum}}</div>
    
                    </div>
                </div>                
            </div>
        </div>

        <!-- subfooter -->
        <!--
        <div v-cloak v-show="numFrissSubModul == 0" class="col-sm-12 col-md-12" style="position: fixed; bottom: 0; width: 100%; background-color: #036f96; height: 150px;">

            <div class="card-deck">
                <div class="card" v-for="outitem in FrissOrderObj.lista">                  
                  <div class="card-block">
                    <h4 class="card-title">{{outitem.mealName}}</h4>
                    <p class="card-text">köret neve</p>
                 </div>
                </div>                             
            </div>            

            <button type="button" class="btn btn-success btn-lg">Megrendelés</button>   
        </div>        
        -->
    </section>

    <section v-if="numVisibleModule == 9" id="TortarendeloListSection">       
        <div v-cloak class="col-sm-12 col-md-12" style="padding-left:2px; padding-right: 2px; margin-top: 58px;">
            <div class="input-group">            
                <div class="input-group-prepend">
                    <button type="button" class="btn btn-primary" v-on:click="showTortaRendeles(0)" title="Új tortarendelés"><i class="fas fa-plus"></i></button>
                </div>
                <input type="text" class="form-control" placeholder="Search" v-model="termekFilterStr">
                <div class="input-group-append">
                    <button type="button" class="btn btn-primary" v-on:click="termekfilter"><i class="fas fa-search"></i></button>
                </div>
            </div>      
        </div>

        <my-tortarendelesek 
            v-for="t in tortarendelesek"   
            v-bind:id="t.id"          
            v-bind:azon="t.megrendeles_azonosito"
            v-bind:partner_name="t.partnev"
            v-bind:price="t.vegosszeg_s"
            v-bind:datum="t.datum"
            v-bind:ido="t.ido"
            v-bind:atvetelhelye="t.atvetel_helye"
            v-bind:torta_tipus="t.torta_tipus"
            v-bind:torta_kategoria="t.torta_kategoria"
            v-bind:torta_neve="t.torta_neve"
            v-bind:keszlet_name="t.keszlet_name"
            v-bind:torta_diszites="t.torta_diszites"
            v-bind:szeletszam="t.szeletszam"
            v-bind:forma="t.forma"
            v-bind:ptr_id="t.ptr_id"
            v-on:goto="showTortaRendeles(t.id)"
            v-on:nyom="printTortaRendeles(t.id)"
            v-on:delete="deleteTortarendeles(t)">                
        </my-tortarendelesek>        

    </section>

    <section v-if="numVisibleModule == 10" id="TortarendeloSection">
        <div v-cloak class="col-sm-12 col-md-12" style="padding-left:2px; padding-right: 2px; margin-top: 58px;">
            <form class="container" id="needs-validation_tortarendeles" novalidate @submit.prevent="submitTortaRendelesData">
                <div class="container">
                    <div class="row">
                        <div class="col-md-9 col-md-offset-2">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                <li class="breadcrumb-item" v-on:click="changeModul(9)"><a href="#">Vissza a tortarendelés listára</a></li>                          
                                </ol>
                            </nav>                   
                        </div>
                        <div class="col-md-3 col-md-offset-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <span v-show="tortaRendelesObj.ptr_id == 0">Rendelés feladása</span>
                                <span v-show="tortaRendelesObj.ptr_id > 0">Rendelés módosítása</span>
                            </button>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 col-md-offset-2">
                            <div class="card">
                                <h3 class="card-header">                        
                                    Megrendelés
                                </h3>
                                <div class="card-block">
                                    <div class="col-md-12 col-md-offset-2"> 
                                        <div class="row">    
                                            <div class="col-md-8 mb-8">
                                                Kereső:
                                            </div>
                                            <div class="col-md-8 mb-8">
                                                <input type="text" autocomplete="off" class="form-control" id="PartnerSearchTR" placeholder=""  v-model="partnerSearchTxtTR">                                        
                                            </div>
                                            <div class="col-md-1 mb-1">
                                                <button type="button" class="btn btn-danger" v-on:click="cancelSearchMatch"><i class="fas fa-times"></i></button>
                                                <br>
                                            </div>
                                        </div>                            
                                        <div class="row">    
                                            <div class="col-md-6 mb-6">
                                                <label for="giveOutName">Név</label>
                                                <input type="text" autocomplete="off" class="form-control" id="TRName" placeholder="" v-model="tortaRendelesObj.partnev" required>
                                                <div class="invalid-feedback">
                                                    Nevet kötelező kitölteni
                                                </div>        
                                            </div>                           
                                            <div class="col-md-6 mb-6">
                                                <label for="giveOutCity">Település</label>
                                                <input type="text" class="form-control" id="TRCity" placeholder="" v-model="tortaRendelesObj.partcity" required>                                    
                                                <div class="invalid-feedback">
                                                    Települést kötelező kitölteni
                                                </div>                                    
                                            </div>
                                        </div>
                                        <div class="row"> 
                                            <div class="col-md-12 mb-12">
                                                <label for="validationCustom02">Cím (utca, házszám)</label>
                                                <input type="text" class="form-control" id="TRAddress" placeholder="" v-model="tortaRendelesObj.partaddress" required>
                                                <div class="invalid-feedback">
                                                    Címet kötelező kitölteni
                                                </div>
                                            </div>                                 
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6 mb-6">
                                                <label for="validationCustom03">Telefonszám</label>
                                                <input type="text" class="form-control" id="TRTelelefon" placeholder="" v-model="tortaRendelesObj.parttel">
                                            </div>
                                            <div class="col-md-6 mb-6">
                                                <label for="validationCustom04">Email</label>
                                                <input type="text" class="form-control" id="TREmail" placeholder="" v-model="tortaRendelesObj.partemail">
                                            </div>
                                        </div>                                                   
                                        <div class="row">
                                            <div class="col-md-3 mb-3">
                                                <label for="validationCustom03">Azonosító</label>
                                                <input type="text" class="form-control" id="TRMegrAzon" placeholder="" v-model="tortaRendelesObj.megrendeles_azonosito">
                                            </div>
                                            <div class="col-md-6 mb-6">
                                                <label for="validationCustom03">Átvétel ideje</label>
                                                <datepicker clear-button-icon="fas fa-times" calendar-button-icon="fas fa-calendar-alt" 
                                                            v-model="tortaRendelesObj.datum" 
                                                            :monday-first="true" :format="customFormatter" 
                                                            :bootstrap-styling="true" :clear-button="true" 
                                                            :typeable="true" :calendar-button="true">
                                                </datepicker>      
                                                <br>                                         
                                            </div>      
                                            <div class="col-md-3 mb-3">
                                                <label for="validationCustom03">Idő</label>
                                                <input type="text" class="form-control" id="TRMegrAzon" placeholder="" v-model="tortaRendelesObj.ido">
                                            </div>                                  
                                        </div>    
                                        <div class="row">
                                            <div class="col-md-6 mb-6">
                                                <label for="validationCustom03">Átvétel helye:</label>
                                                <select class="form-control" id="exampleFormControlSelect1" v-model="tortaRendelesObj.atvetel_helye">
                                                    <option value="VER">Veresegyház</option>
                                                    <option value="GOD">Gödöllő</option>
                                                </select>                                               
                                            </div>                                    
                                            <br>                                                
                                        </div>   
                                        <div class="row">
                                            &nbsp;
                                        </div>                                                                    
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-md-offset-2">
                            <div class="card">
                                <h3 class="card-header">                        
                                    Fizetés/Szállítás                                    
                                </h3>
                                <div class="card-block">
                                    <div class="col-md-12 col-md-offset-2"> 
                                        <br>
                                        <div class="form-group row">                                        
                                            <div class="col-sm-12">
                                                <div class="jumbotron jumbotron-fluid">
                                                    <div class="container">                                                                                                      
                                                        <h1 class="display-4">Végösszeg: {{tortaRendelesObj.vegosszeg_s}} Ft</h1>
                                                        <p class="lead">bruttó</p>
                                                        <p class="lead">Még fizetendő: <b>{{tortaRendelesObj.megfizetendo}} Ft</b></p>
                                                    </div>
                                                </div>                                            
                                            </div>
                                        </div>                                      
                                        <div class="form-group row">
                                            <label for="staticEmail" class="col-sm-2 col-form-label">Előleg:</label>   
                                            <div class="col-sm-4">
                                                <div class="input-group mb-3">
                                                    <input type="text" class="form-control" v-model="tortaRendelesObj.eloleg"  aria-describedby="basic-addon2">
                                                    <div class="input-group-append">
                                                    <span class="input-group-text" id="basic-addon2">Ft</span>
                                                    </div>
                                                </div>                 
                                            </div>      
                                            <label for="staticEmail" class="col-sm-3 col-form-label">Kedvezmény:</label>   
                                            <div class="col-sm-3">
                                                <div class="input-group mb-3">
                                                    <input type="text" class="form-control" v-model="tortaRendelesObj.kedvezmeny_merteke"  aria-describedby="basic-addon2">
                                                    <div class="input-group-append">
                                                    <span class="input-group-text" id="basic-addon2">%</span>
                                                    </div>
                                                </div>                 
                                            </div>                                                                                                    
                                        </div>                                                                            
                                    </div>
                                </div>
                            </div>  
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12 col-md-offset-2">
                            <div class="card">
                                <h3 class="card-header">                        
                                    Torta adatai
                                </h3>
                                <div class="card-block">
                                    <div class="col-md-12 col-md-offset-2"> 
                                        <br>                                         
                                        <div class="form-group row">
                                            <label for="staticEmail" class="col-sm-2 col-form-label">Torta típusa:</label>
                                            <div class="col-sm-8">
                                                <button type="button" class="btn btn-lg" v-on:click="setTortaTipus('N')" v-bind:class="{'btn-warning': tortaRendelesObj.torta_tipus == 'N', 'btn-outline-secondary': tortaRendelesObj.torta_tipus != 'N'}">Normál</button>
                                                <button type="button" class="btn btn-lg" v-on:click="setTortaTipus('B')" v-bind:class="{'btn-warning': tortaRendelesObj.torta_tipus == 'B', 'btn-outline-secondary': tortaRendelesObj.torta_tipus != 'B'}" >Burkolt</button>                                  
                                            </div>
                                            <div class="col-sm-2">
                                                <button type="button" class="btn btn-primary btn-sm" v-on:click="showTortaArazas()">Torta árazása</button>
                                            </div>
                                        </div>    
                                        <div class="form-group row">
                                            <label for="staticEmail" class="col-sm-2 col-form-label">Kategória:</label>
                                            <div class="col-sm-10">
                                                <button type="button" class="btn btn-lg" v-on:click="setTortaKategoria('I')" v-bind:class="{'btn-primary': tortaRendelesObj.torta_kategoria == 'I', 'btn-outline-secondary': tortaRendelesObj.torta_kategoria != 'I'}">I. kategória</button>                                            
                                                <button type="button" class="btn btn-lg" v-on:click="setTortaKategoria('II')" v-bind:class="{'btn-primary': tortaRendelesObj.torta_kategoria == 'II', 'btn-outline-secondary': tortaRendelesObj.torta_kategoria != 'II'}">II. kategória</button>
                                                <button type="button" class="btn btn-lg" v-on:click="setTortaKategoria('III')" v-bind:class="{'btn-primary': tortaRendelesObj.torta_kategoria == 'III', 'btn-outline-secondary': tortaRendelesObj.torta_kategoria != 'III'}">III. kategória</button>
                                                <button type="button" class="btn btn-lg" v-on:click="setTortaKategoria('IV')" v-bind:class="{'btn-primary': tortaRendelesObj.torta_kategoria == 'IV', 'btn-outline-secondary': tortaRendelesObj.torta_kategoria != 'IV'}">IV. kategória</button>
                                                <button type="button" class="btn btn-lg" v-on:click="setTortaKategoria('V')" v-bind:class="{'btn-primary': tortaRendelesObj.torta_kategoria == 'V', 'btn-outline-secondary': tortaRendelesObj.torta_kategoria != 'V'}">V. kategória</button>
                                                <button type="button" class="btn btn-lg" v-on:click="setTortaKategoria('VI')" v-bind:class="{'btn-primary': tortaRendelesObj.torta_kategoria == 'VI', 'btn-outline-secondary': tortaRendelesObj.torta_kategoria != 'VI'}">VI. kategória</button>                                                
                                            </div>
                                        </div>                                                                                                            
                                        <div class="form-group row" v-if="tortaRendelesObj.torta_tipus == 'N'">
                                            <label for="staticEmail" class="col-sm-2 col-form-label">Torta:</label>
                                            <div class="col-sm-10">
                                                <select class="form-control" id="exampleFormControlSelect1" v-model="tortaRendelesObj.product_id">
                                                    <option v-for="termek in termekek" v-bind:value="termek.id">{{termek.name}}</option>
                                                </select>                                       
                                            </div>
                                        </div>                                                                                 
                                        <div class="form-group row" v-if="tortaRendelesObj.torta_tipus == 'B'">
                                            <label for="staticEmail" class="col-sm-2 col-form-label">Torta neve:</label>
                                            <div class="col-sm-10">
                                                <input type="text" class="form-control" id="staticEmail" value="" v-model="tortaRendelesObj.torta_neve">                                            
                                            </div>
                                        </div>                                                                                 
                                        <div class="form-group row" v-if="tortaRendelesObj.torta_tipus == 'B'">
                                            <label for="staticEmail" class="col-sm-2 col-form-label">Díszítés:</label>
                                            <div class="col-sm-10">
                                                <button type="button" class="btn btn-lg" v-on:click="setTortaDiszites('EGY')" v-bind:class="{'btn-primary': tortaRendelesObj.torta_diszites == 'EGY', 'btn-outline-secondary': tortaRendelesObj.torta_diszites != 'EGY'}">Egyszerű</button>
                                                <button type="button" class="btn btn-lg" v-on:click="setTortaDiszites('KUL')" v-bind:class="{'btn-primary': tortaRendelesObj.torta_diszites == 'KUL', 'btn-outline-secondary': tortaRendelesObj.torta_diszites != 'KUL'}">Különleges</button>
                                                <button type="button" class="btn btn-lg" v-on:click="setTortaDiszites('EXT')" v-bind:class="{'btn-primary': tortaRendelesObj.torta_diszites == 'EXT', 'btn-outline-secondary': tortaRendelesObj.torta_diszites != 'EXT'}">Extra</button>
                                            </div>
                                        </div>                                        
                                        <div class="form-group row">
                                            <label for="staticEmail" class="col-sm-2 col-form-label">Szeletek száma:</label>
                                            <div class="col-sm-4">
                                                <input type="text" class="form-control" id="staticEmail" value="" v-model="tortaRendelesObj.szeletszam">
                                            </div>
                                            <div class="col-sm-2">                                            
                                                <span class="badge badge-secondary">{{tortaRendelesObj.szeletar}} Ft / szelet</span>
                                            </div>
                                        </div>          
                                        <div class="form-group row">
                                            <label for="staticEmail" class="col-sm-2 col-form-label">Kiegészítők:</label>
                                            <div class="col-sm-10">
                                                <div class="d-flex flex-wrap">                                                
                                                    <div v-for="(kiegeszito, index) in tortakiegeszitok" class="p-1">
                                                        <strong><span v-bind:title="kiegeszito.EgysegArBrutto">{{kiegeszito.Megnevezes}}</span>:</strong> 
                                                        <input type="text" id="kiegmenny_{{kiegeszito.product_id}}" style="width: 30px;" v-model="kiegeszito.menny"  v-on:input="syncTortaRendelesObjKiegArray(kiegeszito, $event.target.value)"> db
                                                    </div>
                                                </div>
                                            </div>
                                        </div>   
                                        <div class="form-group row">
                                            <label for="staticEmail" class="col-sm-2 col-form-label">Forma leírása:</label>
                                            <div class="col-sm-10">
                                                <input type="text" class="form-control" id="staticEmail" value="" v-model="tortaRendelesObj.forma">
                                            </div>
                                        </div>          
                                        <div class="form-group row">
                                            <label for="staticEmail" class="col-sm-2 col-form-label">Megjegyzés:</label>
                                            <div class="col-sm-10">
                                                <textarea class="form-control" id="exampleFormControlTextarea1" rows="3" v-model="tortaRendelesObj.megjegyzes"></textarea>
                                            </div>
                                        </div>                                                                                                         
                                    </div>                     
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </section>

    <section id="TestConcatSection">
    </section>
</div>

<input type="hidden" id="session_id">

<!--<div id="app2"></div>-->

<!-- template for the modal component -->
<script type="text/x-template" id="modal-template">
    <transition name="modal">
      <div class="modal-mask">
        <div class="modal-wrapper">
          <div class="modal-container">
  
            <div class="modal-header">
              <slot name="header">
                default header
              </slot>
            </div>
  
            <div class="modal-body">
              <slot name="body">
                default body
              </slot>
            </div>
  
            <div class="modal-footer">
              <slot name="footer">                
                <button type="button" class="btn btn-primary btn-lg" v-on:click="$emit('close')">
                    <i class="fab fa-elementor fa-lg"></i>
                    Bezár
                </button>
              </slot>
            </div>
          </div>
        </div>
      </div>
    </transition>
</script>

  

<script type="text/javascript" src="dist/bundle.js"></script>

<script type="text/javascript">
  
            function sendsessioncodetoapp(session_id) {
             console.log("---------------------------------------");
             console.log("sendSessionCodeToApp " + session_id);
             console.log("---------------------------------------");

             // document.getElementById('session_id').value = session_id;
             $( "#session_id" ).val(session_id);

             console.log("---------------------------------------");
             // console.log("==========" + document.getElementById('session_id').value);
             console.log("==========" + $( "#session_id" ).val());
             console.log("---------------------------------------");             
             }                                                 
</script>

</body>